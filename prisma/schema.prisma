generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Film {
  id          BigInt   @id @default(autoincrement())
  title       String
  date        String?
  genre       String?
  comment     String?
  poster      String?

  riskiRating Int
  rapaRating  Int
  riskiSad    Int
  rapaSad     Int

  createdAt   DateTime @default(now())
}